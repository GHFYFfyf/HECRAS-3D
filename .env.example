# DeepSeek API key (required for AI/hybrid model judgment)
DEEPSEEK_API_KEY=

# Optional: deepseek-chat (non-thinking) or deepseek-reasoner (thinking)
DEEPSEEK_MODEL=deepseek-chat

# Optional: both https://api.deepseek.com and https://api.deepseek.com/v1 are valid
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: hydro summary generation temperature (recommended 0.5-0.9)
HYDRO_SUMMARY_TEMPERATURE=0.65

# Optional: rule | ai | hybrid
HYDRO_LABEL_DEFAULT_MODE=hybrid

# Optional compatibility aliases (usually not needed if DEEPSEEK_* is set)
# HYDRO_LABEL_MODEL_API_KEY=
# HYDRO_LABEL_MODEL_NAME=
# HYDRO_LABEL_MODEL_BASE_URL=
